<?xml version="1.0" encoding="utf-8"?>
<!--
    This file provides the overall configuration for your PreTeXt
    project. To edit the content of your document, open `src/aata.xml`
    (default location).
-->
<project>
  <targets>
    <target name="web">
      <format>html</format>
      <source>src/aata.xml</source>
      <publication>publisher/electronic.xml</publication>
      <output-dir>output/web</output-dir>
    </target>
    <target name="runestone">
      <format>html</format>
      <source>src/aata.xml</source>
      <publication>publisher/runestone.xml</publication>
      <output-dir>published/AATA</output-dir>
    </target>
    <target name="print" pdf-method="xelatex">
      <format>pdf</format>
      <source>src/aata.xml</source>
      <publication>publisher/electronic.xml</publication>
      <output-dir>output/print</output-dir>
    </target>
    <target name="print-latex">
      <format>latex</format>
      <source>src/aata.xml</source>
      <publication>publisher/electronic.xml</publication>
      <output-dir>output/print-latex</output-dir>
    </target>
    <target name="v1-exercises-paged" pdf-method="xelatex">
    <format>pdf</format>
    <source>src/aata.xml</source>
    <publication>publisher/v1-exercises-space.xml</publication>
    <output-dir>output/v1-exercises-paged</output-dir>
    <xsl>xsl/v1-exercises-space.xsl</xsl>
</target>
<target name="v1-latex">
    <format>latex</format>
    <source>src/aata.xml</source>
    <publication>publisher/v2-exercises-only.xml</publication>
    <output-dir>output/v1-latex</output-dir>
    <xsl>xsl/v1-exercises-space.xsl</xsl>
</target>
<target name="v2-exercises-only" pdf-method="xelatex">
    <format>pdf</format>
    <source>src/aata.xml</source>
    <publication>publisher/v2-exercises-only.xml</publication>
    <output-dir>output/v2-exercises-only</output-dir>
    <xsl>xsl/v2-exercises.xsl</xsl>
</target>
<target name="v3-content-only" pdf-method="xelatex">
    <format>pdf</format>
    <source>src/aata.xml</source>
    <publication>publisher/v3-content-only.xml</publication>
    <output-dir>output/v3-content-only</output-dir>
    <xsl>xsl/v3-content-only.xsl</xsl>
</target>
<target name="v4-hints" pdf-method="xelatex">
    <format>pdf</format>
    <source>src/aata-hints.xml</source>
    <publication>publisher/v4-hints.xml</publication>
    <output-dir>output/v4-hints</output-dir>
    <!-- <xmlid-root>hints</xmlid-root> -->
</target>
<target name="v5-notation-index" pdf-method="xelatex">
    <format>pdf</format>
    <source>src/aata-notation-index.xml</source>
    <publication>publisher/v5-notation-index.xml</publication>
    <output-dir>output/v5-notation-index</output-dir>
    <!-- <xmlid-root>notation</xmlid-root> -->
</target>
    <target name="subset">
      <format>html</format>
      <source>src/aata.xml</source>
      <publication>publisher/electronic.xml</publication>
      <output-dir>output/subset</output-dir>
      <stringparam key="debug.skip-knowls" value="yes"/>
      <!-- edit this to change the section/chapter/etc. to include
           in your subset build -->
      <xmlid-root>ch_first</xmlid-root>
    </target>
  </targets>
  <executables>
      <latex>latex</latex>
      <pdflatex>pdflatex</pdflatex>
      <xelatex>xelatex</xelatex>
      <pdfsvg>pdf2svg</pdfsvg>
      <asy>asy</asy>
      <sage>sage</sage>
      <pdfpng>convert</pdfpng>
      <pdfeps>pdftops</pdfeps>
      <node>node</node>
      <liblouis>file2brl</liblouis>
    </executables>
</project>
